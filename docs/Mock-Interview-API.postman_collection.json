{
  "info": {
    "name": "Mock Interview API",
    "description": "AI Mock Interview Platform - Backend API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "interviewId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "2. Register",
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Akshat\",\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "3. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "4. Get Me",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "5. Start Interview",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('interviewId', json.interview.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jobRole\": \"Backend Developer\",\n  \"difficulty\": \"medium\"\n}"
        },
        "url": "{{baseUrl}}/api/interviews"
      }
    },
    {
      "name": "6. List Interviews",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/interviews"
      }
    },
    {
      "name": "7. Get Interview by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/interviews/{{interviewId}}"
      }
    },
    {
      "name": "8. Finish Interview",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": "{{baseUrl}}/api/interviews/{{interviewId}}/finish"
      }
    }
  ]
}
